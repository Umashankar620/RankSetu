# ============================================
# RankSetu Backend (Node.js) - .gitignore
# ============================================

# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment variables
.env
.env.production
.env.development
.env.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache
.npm

# Optional eslint cache
.eslintcache

# Output files
dist/
build/
out/

# Temporary folders
tmp/
temp/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS generated files
.DS_Store
Thumbs.db

# PM2 logs
.pm2/

# MySQL data (if local)
*.sql
*.dump
data/
!../database/init.sql
!../database/seed.sql

# Debug
*.log
debug.log

# Uploads
uploads/
files/
temp-uploads/

# Session data
sessions/

# Certificate files
*.pem
*.crt
*.key

# Database local files
*.db
*.sqlite
*.sqlite3

# Config local overrides
config/local.js
config/local.json
*.local.json

# Backup files
*.backup
*.bak
*.old

# Production only files
.env.production.local

# Testing
/coverage
/test-results
