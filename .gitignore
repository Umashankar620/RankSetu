# ============================================
# RankSetu - Root .gitignore
# ============================================

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.code-workspace

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (template only, no actual keys)
.env
.env.*
!.env.example

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup
*.old

# Secrets
*.pem
*.key
*.crt
secrets.json